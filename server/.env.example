# Server environment variables
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file.

# ── Application ───────────────────────────────────────────────────────────────
# Set to "production" via your host's environment variables, not this file.
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret

# Comma-separated list of allowed CORS origins (no trailing slash)
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxx.r2.dev

# ── Geocoding (Nominatim) — all optional, defaults shown ──────────────────────
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_TIMEOUT=10
# NOMINATIM_USER_AGENT=swallow-skyer/1.0
